<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/options"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <!-- Appearance -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/theme_appearance"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeLight"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/theme_light"
                android:textSize="12sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeDark"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/theme_dark"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Cloud (hidden when MainActivity.ENABLE_CLOUD_CONNECT is false) -->
        <LinearLayout
            android:id="@+id/sectionCloud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/cloud_connections"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectGitHub"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:textSize="12sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectGoogleDrive"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- View -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/section_view"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"/>

        <CheckBox
            android:id="@+id/checkLineNumbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:text="@string/line_numbers_toggle"
            android:textSize="14sp"
            app:buttonTint="?attr/colorPrimary"/>

        <!-- Editor -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/config_editor_font_size"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"/>

        <!-- Templates -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/templates"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageTemplates"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/manage_templates"
            android:textSize="13sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditorFontSizeDown"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/decrease_font_size"
                app:icon="@android:drawable/arrow_down_float"
                app:iconTint="?attr/colorOnSurface"/>

            <EditText
                android:id="@+id/editEditorFontSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:minWidth="52dp"
                android:gravity="center"
                android:importantForAutofill="no"
                android:inputType="number"
                android:maxLength="2"
                android:imeOptions="actionDone"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="@string/font_size_sp_unit"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditorFontSizeUp"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/increase_font_size"
                app:icon="@android:drawable/arrow_up_float"
                app:iconTint="?attr/colorOnSurface"/>
        </LinearLayout>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkDebugPro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/debug_pro_toggle"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
